{
  "name": "uistruct",
  "version": "0.5.27",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test --watch=false",
    "lint": "ng lint strct && ng lint showcase",
    "lint:fix": "ng lint strct --fix && ng lint showcase --fix",
    "bundle:analyze": "ng build showcase --configuration production --stats-json && npx source-map-explorer dist/showcase/browser/**/*.js",
    "prepare": "husky"
  },
  "private": true,
  "packageManager": "npm@11.16.0",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.14",
    "@angular/cli": "^21.2.13",
    "@angular/compiler-cli": "^21.2.0",
    "@eslint/js": "^10.0.1",
    "angular-eslint": "21.4.0",
    "eslint": "^10.3.0",
    "husky": "^9.1.7",
    "jsdom": "^28.0.0",
    "lint-staged": "^17.0.7",
    "ng-packagr": "^21.2.0",
    "prettier": "^3.8.1",
    "source-map-explorer": "^2.5.3",
    "typescript": "~5.9.2",
    "typescript-eslint": "8.59.2",
    "vitest": "^3.2.6"
  }
}
